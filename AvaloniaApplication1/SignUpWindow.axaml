<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AvaloniaApplication1.SignUpWindow"
        Title="Sign Up"
        Height="350"
        Width="300"
        Background="#f0f0f0">

    <Grid ColumnDefinitions="50, *, 50" RowDefinitions="50, *, 50, 50, 50, 50, 50, 50, *">
        <TextBlock Grid.Column="1" Grid.Row="0" 
                   Foreground="Black"
                   Text="Sign Up" 
                   FontSize="18"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontWeight="SemiBold"/>

        <StackPanel Grid.Column="1" Grid.Row="1" 
                    VerticalAlignment="Top"
                    Spacing="10"
                    Margin="0,10,0,0">
            <TextBox Name="NameTextBox"
                     Watermark="Name" 
                     Width="200" 
                     Background="White"
                     BorderBrush="#d0d0d0" 
                     Padding="10,5" 
                     Foreground="Gray"
                     HorizontalAlignment="Center"/>
            <TextBox Name="MailTextBox" 
                     Watermark="Email" 
                     Width="200" 
                     Background="White" 
                     BorderBrush="#d0d0d0" 
                     Padding="10,5" 
                     Foreground="Gray"
                     HorizontalAlignment="Center"/>
            <TextBox Name="PasswordTextBox"
                     Watermark="Password"
                     Width="200"
                     Background="White"
                     BorderBrush="#d0d0d0"
                     Padding="10,5"
                     Foreground="Gray"
                     HorizontalAlignment="Center"/>
        </StackPanel>

        <Button Grid.Column="1" Grid.Row="7"
                Content="Sign Up" 
                Click="SignUp"
                HorizontalAlignment="Right"
                Padding="10,5" 
                Background="#e0e0e0"
                BorderThickness="0"
                CornerRadius="4"
                Margin="0,0,10,0"/>

        <TextBlock Grid.Column="1" Grid.Row="8"
                   Name="MessageTextBlock"
                   HorizontalAlignment="Center"
                   Foreground="Red"
                   Margin="0,10,0,0"/>
    </Grid>
</Window>